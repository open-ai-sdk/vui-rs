# Rust (cargo workspace build dir at repo root)
/target

# zig linker cache (cargo-zigbuild cross-compile, build:native:all)
.zig-cache/

# Bun / Node
node_modules/
*.tsbuildinfo

# npm auth (never commit a token; CI writes ~/.npmrc at publish time)
.npmrc

# vite-plus (vp): git hooks + caches are regenerated by `vp config` on install
.vite-hooks/

# Vite SFC build output
/examples-sfc/dist/
/dist/

# Native artifacts copied by scripts/build-native.ts (rebuilt on demand)
/packages/core/native/
/packages/core-*/*.dylib
/packages/core-*/*.so
/packages/core-*/*.dll

.claude/
docs/
# OS noise
.DS_Store

