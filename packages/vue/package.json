{
  "name": "@vui-rs/vue",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "module": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "tsdown"
  },
  "files": ["dist"],
  "publishConfig": {
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  },
  "dependencies": {
    "@vui-rs/core": "workspace:*",
    "@vue/reactivity": "catalog:",
    "@vue/runtime-core": "catalog:"
  }
}
