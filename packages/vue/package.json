{
  "name": "@vui-rs/vue",
  "version": "0.14.1",
  "description": "Vue 3 custom renderer for vui-rs — build reactive terminal UIs with Vue components, reactivity, and lifecycle over the native cell buffer.",
  "keywords": [
    "bun",
    "custom-renderer",
    "renderer",
    "terminal",
    "tui",
    "vue",
    "vui-rs"
  ],
  "homepage": "https://github.com/open-ai-sdk/vui-rs#readme",
  "bugs": "https://github.com/open-ai-sdk/vui-rs/issues",
  "license": "MIT",
  "author": "evann <dacsang97@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/open-ai-sdk/vui-rs.git",
    "directory": "packages/vue"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsdown"
  },
  "dependencies": {
    "@vue/reactivity": "catalog:",
    "@vue/runtime-core": "catalog:",
    "@vui-rs/core": "workspace:*",
    "highlight.js": "^11.11.1",
    "marked": "^18.0.5"
  }
}
