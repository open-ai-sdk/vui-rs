{
  "name": "@vui-rs/vite-plugin",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "module": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "tsdown"
  },
  "files": ["dist"],
  "publishConfig": {
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  },
  "dependencies": {
    "@vitejs/plugin-vue": "catalog:",
    "@vue/compiler-core": "catalog:"
  },
  "peerDependencies": {
    "@vue/compiler-sfc": "catalog:",
    "vite": "catalog:"
  }
}
