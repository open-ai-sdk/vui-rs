{
  "name": "@vui-rs/vite-plugin",
  "version": "0.1.0",
  "description": "Vite plugin to compile .vue SFCs for the vui-rs custom renderer — element tags, a TUI v-model transform, and style-block stripping.",
  "keywords": [
    "sfc",
    "terminal",
    "tui",
    "vite",
    "vite-plugin",
    "vue",
    "vui-rs"
  ],
  "homepage": "https://github.com/open-ai-sdk/vui-rs#readme",
  "bugs": "https://github.com/open-ai-sdk/vui-rs/issues",
  "license": "MIT",
  "author": "evann <dacsang97@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/open-ai-sdk/vui-rs.git",
    "directory": "packages/vite-plugin"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "module": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "publishConfig": {
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    },
    "access": "public"
  },
  "scripts": {
    "build": "tsdown"
  },
  "dependencies": {
    "@vitejs/plugin-vue": "catalog:",
    "@vue/compiler-core": "catalog:"
  },
  "peerDependencies": {
    "@vue/compiler-sfc": "catalog:",
    "vite": "catalog:"
  }
}
