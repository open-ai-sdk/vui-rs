{
  "name": "@vui-rs/rolldown",
  "version": "0.1.2",
  "description": "Compile .vue SFCs for the vui-rs custom renderer in rolldown/tsdown builds (unplugin-vue + vui compiler options + style strip).",
  "keywords": [
    "rolldown",
    "sfc",
    "terminal",
    "tsdown",
    "tui",
    "vue",
    "vui-rs"
  ],
  "homepage": "https://github.com/open-ai-sdk/vui-rs#readme",
  "bugs": "https://github.com/open-ai-sdk/vui-rs/issues",
  "license": "MIT",
  "author": "evann <dacsang97@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/open-ai-sdk/vui-rs.git",
    "directory": "packages/rolldown"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsdown"
  },
  "dependencies": {
    "@vue/compiler-core": "catalog:",
    "@vui-rs/vite-plugin": "workspace:*",
    "unplugin-vue": "^7"
  },
  "devDependencies": {
    "rolldown": "~1.1.0"
  },
  "peerDependencies": {
    "rolldown": "^1"
  },
  "peerDependenciesMeta": {
    "rolldown": {
      "optional": true
    }
  }
}
