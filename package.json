{
  "name": "vui-rs",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": {
    "packages": ["packages/*", "examples", "examples-sfc"],
    "catalog": {
      "@vitejs/plugin-vue": "^6.0.0",
      "@vue/compiler-core": "3.5.35",
      "@vue/compiler-sfc": "3.5.35",
      "@vue/reactivity": "3.5.35",
      "@vue/runtime-core": "3.5.35",
      "vite": "^8.0.0"
    }
  },
  "scripts": {
    "build:native": "bun run scripts/build-native.ts",
    "build:packages": "bun run --filter './packages/*' build",
    "dev": "bun run examples/smoke-version.ts",
    "build:sfc": "bun run --filter @vui-rs/examples-sfc build",
    "start:sfc": "bun run --filter @vui-rs/examples-sfc start",
    "dev:sfc": "bun run --filter @vui-rs/examples-sfc dev",
    "typecheck:sfc": "vue-tsc --noEmit",
    "test": "cargo test -p vui-core && bun test packages/core/test packages/vue/test packages/vite-plugin/test && bun run examples/smoke-version.ts"
  },
  "devDependencies": {
    "@types/bun": "^1.3.0",
    "@vue/compiler-sfc": "catalog:",
    "@vue/runtime-core": "catalog:",
    "tsdown": "^0.22.1",
    "typescript": "^5.9.0",
    "vue-tsc": "^2.2.0"
  }
}
