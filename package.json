{
  "name": "vui-rs",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": {
    "packages": [
      "packages/*",
      "examples/*"
    ],
    "catalog": {
      "@vitejs/plugin-vue": "^6.0.0",
      "@vue/compiler-core": "3.5.35",
      "@vue/compiler-sfc": "3.5.35",
      "@vue/reactivity": "3.5.35",
      "@vue/runtime-core": "3.5.35",
      "vite": "^8.0.0"
    }
  },
  "scripts": {
    "build:native": "bun run scripts/build-native.ts",
    "build:packages": "bun run --filter './packages/*' build",
    "build:examples": "bun run --filter '@vui-rs/example-*' build",
    "dev:form": "bun run --filter @vui-rs/example-form build && bun examples/form/dist/app.js",
    "dev:textarea": "bun run --filter @vui-rs/example-textarea build && bun examples/textarea/dist/app.js",
    "dev:markdown": "bun run --filter @vui-rs/example-markdown build && bun examples/markdown/dist/app.js",
    "dev:diff": "bun run --filter @vui-rs/example-diff build && bun examples/diff/dist/app.js",
    "dev:animation": "bun run --filter @vui-rs/example-animation build && bun examples/animation/dist/app.js",
    "dev:theme-switch": "bun run --filter @vui-rs/example-theme-switch build && bun examples/theme-switch/dist/app.js",
    "dev:images": "bun run --filter @vui-rs/example-images build && bun examples/images/dist/app.js",
    "dev:selection": "bun run --filter @vui-rs/example-selection build && bun examples/selection/dist/app.js",
    "dev": "bun run scripts/abi-probe.ts",
    "typecheck:sfc": "vue-tsc --noEmit",
    "bench": "bun run examples/paint-bench.ts >/dev/null",
    "test": "cargo test -p vui-core && bun test packages/core/test packages/vue/test packages/vite-plugin/test && bun run scripts/abi-probe.ts"
  },
  "devDependencies": {
    "@types/bun": "^1.3.0",
    "@vue/compiler-sfc": "catalog:",
    "@vue/runtime-core": "catalog:",
    "@vui-rs/core": "workspace:*",
    "@vui-rs/vue": "workspace:*",
    "tsdown": "^0.22.1",
    "typescript": "^5.9.0",
    "vite": "catalog:",
    "vue-tsc": "^2.2.0"
  }
}
