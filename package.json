{
  "name": "vui-rs",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": ["packages/*", "examples", "examples-sfc"],
  "scripts": {
    "build:native": "bun run scripts/build-native.ts",
    "dev": "bun run examples/smoke-version.ts",
    "build:sfc": "vite build",
    "start:sfc": "bun examples-sfc/dist/app.js",
    "dev:sfc": "vite build && bun examples-sfc/dist/app.js",
    "test": "cargo test -p vui-core && bun test packages/core/test packages/vue/test packages/vite-plugin/test && bun run examples/smoke-version.ts"
  },
  "devDependencies": {
    "@types/bun": "^1.3.0",
    "@vitejs/plugin-vue": "^5.2.0",
    "@vue/compiler-core": "3.5.35",
    "@vue/compiler-sfc": "3.5.35",
    "@vue/runtime-core": "3.5.35",
    "typescript": "^5.9.0",
    "vite": "^7.0.0"
  }
}
